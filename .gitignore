# ============================================================
# Venora — .gitignore
# Stack: Next.js 15 (App Router) + Convex + Vitest + Playwright
# ============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js ---
.next/
out/
build/
dist/
next-env.d.ts
*.tsbuildinfo

# --- Convex ---
# Generated files — regenerated by `convex dev`/`convex codegen`
convex/_generated/

# --- Environment variables ---
# NEVER commit any .env file with real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Keep the template committed
!.env.example

# --- Testing ---
# Vitest
coverage/
.vitest-cache/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# --- React Email ---
.react-email/

# --- TypeScript ---
*.tsbuildinfo

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editor / IDE ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Vercel ---
.vercel

# --- Misc caches ---
.cache/
.turbo/
.eslintcache
.stylelintcache

# --- Local scratch / notes ---
# For personal TODO files, scratch notes, local dumps
/.scratch/
/notes/
TODO.local.md
SCRATCH.md

# --- Package manager lock files ---
# Keep your chosen one, ignore the others
# (Assuming pnpm — uncomment the lines for locks you DON'T use)
# package-lock.json
# yarn.lock
# bun.lockb